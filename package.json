{
  "type": "module",
  "name": "spotify-mcp-server",
  "description": "A Model Context Protocol server for Spotify integration",
  "author": {
    "email": "agustinho.pneto@gmail.com",
    "name": "Agustinho Neto",
    "url": "https://www.github.com/agustinhopneto"
  },
  "version": "1.0.0",
  "main": "./src/index.ts",
  "bin": {
    "spotify-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "auth": "tsc && node build/auth.js",
    "lint": "biome check --diagnostic-level=warn --error-on-warnings",
    "lint:fix": "biome check --write --unsafe --organize-imports-enabled=true",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build -d spotify-mcp",
    "docker:down": "docker compose down",
    "docker:auth": "docker compose run --rm --service-ports spotify-auth",
    "docker:logs": "docker compose logs -f spotify-mcp"
  },
  "files": ["build"],
  "keywords": ["MCP", "Spotify"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
